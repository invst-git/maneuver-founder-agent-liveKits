# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch
AGENT_NAME=

# Lead storage
LEADS_FILE=../data/leads.jsonl
LEADS_API_KEY=

# Optional local transcript debugging. Keep disabled unless you explicitly need it.
ENABLE_TRANSCRIPT_DEBUG=false
TRANSCRIPTS_FILE=../data/transcripts.jsonl

# Follow-up email. Disabled unless explicitly enabled.
FOLLOWUP_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
INTERNAL_LEAD_EMAIL=

# Voice tuning
TTS_MODEL=cartesia/sonic-3
TTS_VOICE=228fca29-3a0a-435c-8728-5cb483251068
TTS_LANGUAGE=en
TTS_SPEED=0.98
TTS_VOLUME=1.0
# Optional. Leave blank unless the configured TTS model accepts the value.
TTS_EMOTION=

# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
